# GRIDHAND Workers — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to git.
# Source of truth for required keys: Railway production environment.

# ─── Supabase ─────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Redis (Upstash — for SMS deduplication across Railway cold starts)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ─── AI Providers ─────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=AIzaSy...
PERPLEXITY_API_KEY=pplx-...
DEEPSEEK_API_KEY=sk-...

# Ollama — local model server (activates local-first routing when set)
OLLAMA_BASE_URL=https://your-tunnel.trycloudflare.com
OLLAMA_FIRST=true

# ─── Search & Scraping ────────────────────────────────────────────────────────

EXA_API_KEY=...
FIRECRAWL_API_KEY=fc-...

# ─── Google Maps & Places ─────────────────────────────────────────────────────

GOOGLE_MAPS_API_KEY=AIzaSy...
GOOGLE_PLACES_API_KEY=AIzaSy...

# ─── Voice (ElevenLabs + Twilio Voice Bridge) ─────────────────────────────────

ELEVENLABS_API_KEY=...
VOICE_BRIDGE_HMAC_SECRET=...

# ─── Twilio ───────────────────────────────────────────────────────────────────

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
ADMIN_NOTIFY_PHONES=+1xxxxxxxxxx

# ─── Telegram (MJ agent alerts) ───────────────────────────────────────────────

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ─── Stripe ───────────────────────────────────────────────────────────────────

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Make.com Automation ──────────────────────────────────────────────────────

MAKE_API_KEY=...
MAKE_TEAM_ID=...
MAKE_ZONE=us2
MAKE_OUTBOUND_WEBHOOK_URL=https://hook.us2.make.com/...
MAKE_WEBHOOK_SECRET=...

# Make.com workflow-specific hooks (one per automation scenario)
MAKE_HOOK_APPOINTMENT_BOOKED=https://hook.us2.make.com/...
MAKE_HOOK_APPOINTMENT_FLOW=https://hook.us2.make.com/...
MAKE_HOOK_APPOINTMENT_REMINDER=https://hook.us2.make.com/...
MAKE_HOOK_DUNNING_RECOVERY=https://hook.us2.make.com/...
MAKE_HOOK_INVOICE_CHASER=https://hook.us2.make.com/...
MAKE_HOOK_LEAD_NURTURE=https://hook.us2.make.com/...
MAKE_HOOK_LEAD_SPEED=https://hook.us2.make.com/...
MAKE_HOOK_MISSED_CALL=https://hook.us2.make.com/...
MAKE_HOOK_NO_SHOW=https://hook.us2.make.com/...
MAKE_HOOK_REACTIVATION=https://hook.us2.make.com/...
MAKE_HOOK_REFERRAL=https://hook.us2.make.com/...
MAKE_HOOK_REPAIR_READY=https://hook.us2.make.com/...
MAKE_HOOK_REVIEW_PIPELINE=https://hook.us2.make.com/...
MAKE_HOOK_REVIEW_RESPONSE=https://hook.us2.make.com/...
MAKE_HOOK_STATUS_UPDATED=https://hook.us2.make.com/...
MAKE_HOOK_UPSELL=https://hook.us2.make.com/...

# ─── n8n ──────────────────────────────────────────────────────────────────────

N8N_BASE_URL=https://gridhand-n8n-production.up.railway.app
N8N_API_KEY=your_n8n_api_key_here

# ─── Observability ────────────────────────────────────────────────────────────

SENTRY_AUTH_TOKEN=sntryu_...
SENTRY_DSN=https://your-dsn@sentry.io/project-id
POSTHOG_API_KEY=phc_...
LINEAR_API_KEY=lin_api_...

# ─── Personalized AI Memory (Mem0) ────────────────────────────────────────────
# Per-client persistent memory injected into every worker conversation.
# Get your key: https://app.mem0.ai/dashboard/api-keys

MEM0_API_KEY=your_mem0_api_key_here

# ─── Security & Encryption ────────────────────────────────────────────────────

FIELD_ENCRYPTION_KEY=...
WORKERS_API_SECRET=...

# ─── Email ────────────────────────────────────────────────────────────────────

RESEND_API_KEY=re_...

# ─── Portal / Workers URLs ────────────────────────────────────────────────────

WORKERS_BASE_URL=https://gridhand-workers-production.up.railway.app
NEXT_PUBLIC_WORKERS_URL=https://gridhand-workers-production.up.railway.app
WORKERS_API_KEY=your_workers_api_key
GRIDHAND_API_KEY=your_internal_api_key
PORTAL_BASE_URL=https://gridhand.ai
PORTAL_URL=https://gridhand-portal.vercel.app
NEXT_PUBLIC_APP_URL=https://gridhand.ai

# ─── Cron Schedules ───────────────────────────────────────────────────────────

DAILY_DIGEST_CRON=0 14 * * *
