# GRIDHAND Workers — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to git.

# ─── Core Infrastructure ──────────────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Redis (Upstash — for SMS deduplication across Railway cold starts)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ─── AI Providers ─────────────────────────────────────────────────────────────

# Anthropic (Claude) — used by SMS workers
ANTHROPIC_API_KEY=sk-ant-...

# Groq — free, fast. Used by scenario engine (llama-3.3-70b-versatile) and agents.
GROQ_API_KEY=gsk_...

# Ollama — local model server (optional, activates local-first mode)
# OLLAMA_BASE_URL=https://your-tunnel.trycloudflare.com
# OLLAMA_FIRST=true

# Moonshot / Kimi (fallback AI)
# MOONSHOT_API_KEY=sk-...

# Perplexity (fallback AI)
# PERPLEXITY_API_KEY=pplx-...

# ─── Twilio ───────────────────────────────────────────────────────────────────

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# ─── ElevenLabs (voice bridge) ────────────────────────────────────────────────

ELEVENLABS_API_KEY=your_elevenlabs_key

# ─── GRIDHAND Portal ──────────────────────────────────────────────────────────

# Internal API key for worker → portal calls
GRIDHAND_API_KEY=your_internal_api_key
PORTAL_BASE_URL=https://app.gridhand.ai

# ─── N8N Scenario Engine ──────────────────────────────────────────────────────

# n8n self-hosted instance URL
N8N_BASE_URL=https://gridhand-n8n-production.up.railway.app

# n8n REST API key — generate in n8n Settings → API → Create API Key
# If not set: scenarios are saved to /scenarios/ on disk only (still importable)
# N8N_API_KEY=your_n8n_api_key_here

# GRIDHAND workers public URL — used by industry-scenario-builder.js to set the
# HTTP Request node target inside generated n8n workflows. Must be the live
# Railway URL so n8n can reach the workers when a workflow fires.
WORKERS_BASE_URL=https://gridhand-workers-production.up.railway.app

# n8n city data webhook — PRIMARY route for city database queries (lib/city-data.js)
# When set, business license / permit queries route through n8n for normalization
# across all city portal types (CKAN, Socrata, ArcGIS). Falls back to direct CSV
# download when not set. Create in n8n: Webhook trigger → city data lookup logic.
# Accepts:  { city, state, dataset, resourceId, portalUrl, limit }
# Returns:  { records: [...], total: N, source_label: '...' }
# N8N_CITY_DATA_WEBHOOK=https://gridhand-n8n-production.up.railway.app/webhook/city-data

# ─── Notifications ────────────────────────────────────────────────────────────

# Telegram (for MJ alerts from agents)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ─── Deploy Watch ─────────────────────────────────────────────────────────────

# Workers own API key (used by deploy-watch health checks)
WORKERS_API_KEY=your_workers_api_key

# Railway deploy hook (optional — triggers redeploy from portal)
RAILWAY_DEPLOY_HOOK_URL=https://backboard.railway.com/webhooks/deploy/...
