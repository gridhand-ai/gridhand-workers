# ─────────────────────────────────────────────────────────────
# GRIDHAND Review Closer — Environment Variables
# Copy to .env and fill in all values before running
# ─────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Tekmetric ────────────────────────────────────────────────
# API base URL: sandbox for dev, production for live
TEKMETRIC_BASE_URL=https://sandbox.tekmetric.com/api/v1
# Your Tekmetric API bearer token
TEKMETRIC_API_KEY=your_tekmetric_api_key_here
# Webhook secret for validating incoming Tekmetric webhooks
TEKMETRIC_WEBHOOK_SECRET=your_webhook_secret_here

# ── Google Business Profile ───────────────────────────────────
# Path to your Google service account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account.json
# OR inline the JSON as a base64 string (preferred for deployments)
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON=base64_encoded_json_here

# Your Google Business Profile Account ID (from GBP dashboard URL)
# Format: accounts/1234567890
GOOGLE_ACCOUNT_ID=accounts/YOUR_ACCOUNT_ID

# Default location ID if shop has only one location
# Format: accounts/1234567890/locations/9876543210
GOOGLE_LOCATION_ID=accounts/YOUR_ACCOUNT_ID/locations/YOUR_LOCATION_ID

# ── Twilio ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# The Twilio phone number to send SMS from (E.164 format)
TWILIO_FROM_NUMBER=+15551234567

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Redis (for Bull job queue) ────────────────────────────────
REDIS_URL=redis://localhost:6379
# OR individual fields if not using a URL:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── Review Closer Settings ────────────────────────────────────
# Hours to wait after RO completion before sending SMS
REVIEW_REQUEST_DELAY_HOURS=2
# How often to poll Google Business for new reviews (minutes)
REVIEW_MONITOR_INTERVAL_MINUTES=15
# Max review requests to send per day per shop (rate limiting)
MAX_REVIEW_REQUESTS_PER_DAY=50

# ── Security ─────────────────────────────────────────────────
# API key for admin endpoints (generate a strong random string)
GRIDHAND_API_KEY=your_secure_api_key_here
